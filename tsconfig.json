{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["chrome", "vite/client"],
    "paths": {
      "@getsimpl/core": ["../getsimpl-core/packages/core/src/index.ts"],
      "@getsimpl/chains": ["../getsimpl-core/packages/chains/src/index.ts"],
      "@getsimpl/formatters": ["../getsimpl-core/packages/formatters/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}